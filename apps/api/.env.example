# Runtime.
NODE_ENV=development
PORT=3000

# CORS.
# Add production and preview web origins as comma-separated exact origins.
CORS_ORIGINS=https://vscoke.vercel.app,http://localhost:3000,http://127.0.0.1:3000

# Google OAuth token verification.
GOOGLE_CLIENT_ID=replace-with-google-client-id

# PostgreSQL.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=replace-with-db-password
DB_DATABASE=vscoke
DB_SYNCHRONIZE=false

# Optional production error notification endpoint.
# If any value is empty, notification delivery is skipped.
NOTIFY_SERVICE_URL=
NOTIFY_SERVICE_USER=
NOTIFY_SERVICE_PASSWORD=

# Development-only auth bypass. Do not set in production.
ENABLE_DEV_AUTH_BYPASS=false
DEV_AUTH_TOKEN=

# Development-only Poke Lounge local single test mode.
LOCAL_TEST_AUTH_TOKEN=

# Local database tunnel helper: pnpm --filter @vscoke/api db:tunnel
CLOUDFLARE_DB_HOST=

# Resume RAG.
# Runtime chat uses DB text/keyword search over resume_source_items.
# Embedding/vector settings below are optional legacy/future indexing settings,
# not required for production chat.
RAG_EMBEDDING_PROVIDER=
RAG_EMBEDDING_MODEL=
RAG_EMBEDDING_DIMENSIONS=

# Required for natural-language answer generation.
RAG_CHAT_PROVIDER=codex-app-server
# Optional. If empty, Codex app-server uses its configured default model.
RAG_CHAT_MODEL=
RAG_CODEX_MODEL_PROVIDER=
# Ubuntu host default: Codex app-server loopback endpoint.
RAG_CODEX_APP_SERVER_URL=ws://127.0.0.1:14561
# Ubuntu host release directory used as Codex working directory.
RAG_CODEX_CWD=/home/icenux/projects/vscoke-api
RAG_CODEX_TIMEOUT_MS=120000

# Public chat browser-origin allowlist.
# Production default is https://vscoke.vercel.app. Set explicitly in operation.
RAG_PUBLIC_CHAT_ORIGINS=https://vscoke.vercel.app

# Required only for optional openai-compatible embedding/vector indexing.
RAG_AI_BASE_URL=
RAG_AI_API_KEY=

RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.1
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=120
RAG_ALLOWED_VISIBILITIES=public
