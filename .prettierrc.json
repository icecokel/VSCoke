{
  "printWidth": 100,
  "tabWidth": 2,
  "semi": true,
  "proseWrap": "preserve",
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "overrides": [
    {
      "files": "apps/api/**/*.{js,mjs,cjs,ts}",
      "options": {
        "singleQuote": true,
        "printWidth": 80,
        "arrowParens": "always"
      }
    }
  ]
}
