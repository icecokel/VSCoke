# Runtime.
NODE_ENV=development
PORT=3000

# CORS.
# Add production and preview web origins as comma-separated exact origins.
CORS_ORIGINS=https://vscoke.vercel.app,http://localhost:3000

# Google OAuth token verification.
GOOGLE_CLIENT_ID=replace-with-google-client-id

# PostgreSQL.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=replace-with-db-password
DB_DATABASE=vscoke
DB_SYNCHRONIZE=false

# Optional production error notification endpoint.
# In production, the API currently falls back to localhost when this is empty.
NOTIFY_SERVICE_URL=
NOTIFY_SERVICE_USER=
NOTIFY_SERVICE_PASSWORD=

# Development-only auth bypass. Do not set in production.
ENABLE_DEV_AUTH_BYPASS=false
DEV_AUTH_TOKEN=

# Local database tunnel helper: pnpm --filter @vscoke/api db:tunnel
CLOUDFLARE_DB_HOST=

# Resume RAG.
# Embedding remains a separate vector-search dependency.
RAG_EMBEDDING_PROVIDER=
RAG_EMBEDDING_MODEL=
RAG_EMBEDDING_DIMENSIONS=

# Natural-language answer generation runs through Codex app-server.
RAG_CHAT_PROVIDER=codex-app-server
# Optional. If empty, Codex app-server uses its configured default model.
RAG_CHAT_MODEL=
RAG_CODEX_MODEL_PROVIDER=
RAG_CODEX_APP_SERVER_URL=ws://127.0.0.1:14561
RAG_CODEX_CWD=
RAG_CODEX_TIMEOUT_MS=120000

# Required only when RAG_*_PROVIDER=openai-compatible.
RAG_AI_BASE_URL=
RAG_AI_API_KEY=

RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.78
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=120
RAG_ALLOWED_VISIBILITIES=public
