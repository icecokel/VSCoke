{
  "name": "@vscoke/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "e2e": "node scripts/playwright-runner.mjs test",
    "e2e:codegen": "node scripts/playwright-runner.mjs codegen",
    "e2e:cross-browser": "PLAYWRIGHT_ENABLE_CROSS_BROWSER=1 node scripts/playwright-runner.mjs test",
    "e2e:headed": "node scripts/playwright-runner.mjs test --headed",
    "e2e:install": "playwright install chromium firefox webkit",
    "e2e:report": "playwright show-report",
    "e2e:server": "NEXT_DIST_DIR=.next-e2e PLAYWRIGHT_PORT=37123 node scripts/playwright-web-server.mjs",
    "e2e:smoke": "node scripts/playwright-runner.mjs test tests/e2e/i18n-integrity.spec.ts --project=chromium",
    "e2e:ui": "node scripts/playwright-runner.mjs test --ui",
    "e2e:update-snapshots": "node scripts/playwright-runner.mjs test tests/e2e/visual-regression.spec.ts --project=chromium --update-snapshots",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type:check": "tsc --noEmit",
    "knip": "knip --no-progress --include files,dependencies,unlisted,unresolved",
    "generate:types": "openapi-typescript ../api/openapi.json -o src/types/api.d.ts"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-context-menu": "^2.3.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@radix-ui/react-visually-hidden": "^1.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "next": "^15.5.19",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.13.0",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "phaser": "^3.90.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reading-time": "^1.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.14",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.19",
    "knip": "^5.88.1",
    "openapi-typescript": "^7.10.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
