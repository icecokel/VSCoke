# Runtime.
NODE_ENV=development
PORT=3000

# CORS.
# Add production and preview web origins as comma-separated exact origins.
CORS_ORIGINS=https://vscoke.vercel.app,http://localhost:3000

# Google OAuth token verification.
GOOGLE_CLIENT_ID=replace-with-google-client-id

# PostgreSQL.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=replace-with-db-password
DB_DATABASE=vscoke
DB_SYNCHRONIZE=false

# GeekNews sync and translation.
GEEKNEWS_SYNC_ENABLED=true
GEEKNEWS_CRAWL_PAGE_LIMIT=3
GEEKNEWS_TRANSLATION_PROVIDER=gemini
GEEKNEWS_TRANSLATION_TARGET_LANGUAGE=en
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional production error notification endpoint.
# In production, the API currently falls back to localhost when this is empty.
NOTIFY_SERVICE_URL=
NOTIFY_SERVICE_USER=
NOTIFY_SERVICE_PASSWORD=

# Development-only auth bypass. Do not set in production.
ENABLE_DEV_AUTH_BYPASS=false
DEV_AUTH_TOKEN=

# Local database tunnel helper: pnpm --filter @vscoke/api db:tunnel
CLOUDFLARE_DB_HOST=
