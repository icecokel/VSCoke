# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/
playwright-report/
/.playwright-mcp/
test-results/

# next.js
.next/
.next-e2e/
.next-e2e-*/
.next-e2e-tsconfig-*.json
out/

# production
build/
dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!apps/api/.env.example
!apps/web/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude
.claude/settings.local.json

# serena
.serena/

# plan
/plan

# git worktrees
/worktrees/

