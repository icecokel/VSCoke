{
  "name": "vscoke",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @vscoke/web dev",
    "dev:web": "pnpm --filter @vscoke/web dev",
    "dev:api": "pnpm build:poke-lounge-battle && pnpm --parallel --stream --filter @vscoke/poke-lounge-battle --filter @vscoke/api dev",
    "build": "pnpm --filter @vscoke/poke-lounge-battle build && pnpm --filter @vscoke/web build && pnpm --filter @vscoke/api build",
    "build:poke-lounge-battle": "pnpm --filter @vscoke/poke-lounge-battle build",
    "check:poke-lounge-battle-resolution": "node scripts/check-poke-lounge-battle-resolution.mjs types && pnpm build:poke-lounge-battle && node scripts/check-poke-lounge-battle-resolution.mjs runtime",
    "build:web": "pnpm --filter @vscoke/web build",
    "build:api": "pnpm build:poke-lounge-battle && pnpm --filter @vscoke/api build",
    "start": "pnpm --filter @vscoke/web start",
    "start:web": "pnpm --filter @vscoke/web start",
    "start:api": "pnpm --filter @vscoke/api start:prod",
    "e2e": "pnpm --filter @vscoke/web e2e",
    "e2e:codegen": "pnpm --filter @vscoke/web e2e:codegen",
    "e2e:cross-browser": "pnpm --filter @vscoke/web e2e:cross-browser",
    "e2e:headed": "pnpm --filter @vscoke/web e2e:headed",
    "e2e:install": "pnpm --filter @vscoke/web e2e:install",
    "e2e:local-test-mode": "pnpm --filter @vscoke/web e2e:local-test-mode",
    "e2e:report": "pnpm --filter @vscoke/web e2e:report",
    "e2e:server": "pnpm --filter @vscoke/web e2e:server",
    "e2e:smoke": "pnpm --filter @vscoke/web e2e:smoke",
    "e2e:ui": "pnpm --filter @vscoke/web e2e:ui",
    "e2e:update-snapshots": "pnpm --filter @vscoke/web e2e:update-snapshots",
    "lint": "pnpm --filter @vscoke/poke-lounge-battle lint && pnpm --filter @vscoke/web lint && pnpm --filter @vscoke/api lint",
    "lint:web": "pnpm --filter @vscoke/web lint",
    "lint:fix": "pnpm --filter @vscoke/web lint:fix && pnpm --filter @vscoke/api lint:fix",
    "lint:fix:web": "pnpm --filter @vscoke/web lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type:check": "pnpm --filter @vscoke/web type:check",
    "type:check:web": "pnpm --filter @vscoke/web type:check",
    "test": "pnpm test:poke-lounge-battle && pnpm test:web && pnpm test:api",
    "test:poke-lounge-battle": "pnpm --filter @vscoke/poke-lounge-battle test -- --runInBand",
    "test:web": "pnpm --filter @vscoke/web test:poke-lounge-unit",
    "test:api": "pnpm build:poke-lounge-battle && pnpm --filter @vscoke/api test",
    "test:api:e2e": "pnpm build:poke-lounge-battle && pnpm --filter @vscoke/api test:e2e",
    "poke-lounge:audio:verify": "node scripts/poke-lounge/verify-audio-assets.mjs",
    "check:poke-lounge-provenance": "node scripts/poke-lounge/check-asset-provenance.mjs",
    "smoke:api:remote": "node scripts/check-api-health.mjs",
    "knip": "pnpm --filter @vscoke/web knip",
    "generate:openapi": "pnpm build:poke-lounge-battle && pnpm --filter @vscoke/api openapi:generate",
    "generate:types": "pnpm generate:openapi && prettier --write apps/api/openapi.json && pnpm --filter @vscoke/web generate:types && prettier --write apps/web/src/types/api.d.ts",
    "check:api-contract": "pnpm generate:types && git diff --exit-code apps/api/openapi.json apps/web/src/types/api.d.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0"
  }
}
