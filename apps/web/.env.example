# Public API endpoint used by browser code.
NEXT_PUBLIC_API_URL=https://api.icecoke.kr

# Auth.js / Google OAuth.
AUTH_GOOGLE_ID=replace-with-google-client-id
AUTH_GOOGLE_SECRET=replace-with-google-client-secret
AUTH_SECRET=replace-with-random-secret

# Development-only Poke Lounge local single test mode.
LOCAL_TEST_AUTH_TOKEN=

# Optional. Set explicitly only when the deployment platform cannot infer it.
# AUTH_URL=https://vscoke.vercel.app

# Optional. Google Analytics 4 measurement ID for direct gtag.js setup.
# Example: G-ABCDEFG123
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional. Google Tag Manager web container ID for GA4 and marketing tags.
# Example: GTM-ABCDEFG
NEXT_PUBLIC_GTM_ID=
